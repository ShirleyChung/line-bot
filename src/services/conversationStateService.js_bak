import fs from "fs";
import path from "path";

/**
 * 使用簡易的 JSON 檔保存對話狀態
 * key 例如：
 * - user:U123456
 * - group:G999999
 */
const STATE_FILE = path.resolve("./data/conversation-state.json");

/**
 * 記憶體中的狀態表
 * 結構範例：
 * {
 *   "user:Uxxx": {
 *     "lastResponseId": "resp_abc123",
 *     "updatedAt": "2026-04-29T12:00:00.000Z"
 *   }
 * }
 */
const stateMap = {};

/**
 * 啟動時讀入狀態表
 */
export function loadConversationStateFile() {
  try {
    const dir = path.dirname(STATE_FILE);
    if (!fs.existsSync(dir)) {
      fs.mkdirSync(dir, { recursive: true });
    }

    if (!fs.existsSync(STATE_FILE)) {
      fs.writeFileSync(STATE_FILE, "{}", "utf8");
      return;
    }

    const text = fs.readFileSync(STATE_FILE, "utf8");
    const parsed = JSON.parse(text);

    Object.assign(stateMap, parsed);
    console.log("conversation-state loaded");
  } catch (err) {
    console.error("loadConversationStateFile error:", err);
  }
}

/**
 * 將目前記憶體狀態寫回檔案
 */
export function saveConversationStateFile() {
  try {
    const dir = path.dirname(STATE_FILE);
    if (!fs.existsSync(dir)) {
      fs.mkdirSync(dir, { recursive: true });
    }

    fs.writeFileSync(STATE_FILE, JSON.stringify(stateMap, null, 2), "utf8");
  } catch (err) {
    console.error("saveConversationStateFile error:", err);
  }
}

/**
 * 根據 LINE source 建立 session key
 * - 一對一：user:Uxxxx
 * - 群組：group:Gxxxx
 * - room：room:Rxxxx
 */
export function buildSessionKey(source) {
  if (!source || !source.type) {
    return "unknown";
  }

  if (source.type === "user") {
    return `user:${source.userId}`;
  }

  if (source.type === "group") {
    return `group:${source.groupId}`;
  }

  if (source.type === "room") {
    return `room:${source.roomId}`;
  }

  return "unknown";
}

/**
 * 讀取指定 session 的狀態
 */
export function getConversationState(sessionKey) {
  return stateMap[sessionKey] || null;
}

/**
 * 更新指定 session 的 lastResponseId
 * 這裡同步也將狀態寫回檔案，避免重啟後遺失對話記錄
 */
export function setConversationState(sessionKey, lastResponseId) {
  stateMap[sessionKey] = {
    lastResponseId,
    updatedAt: new Date().toISOString(),
  };

  saveConversationStateFile();
}